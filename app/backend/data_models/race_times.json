{
    "title": "race_times",
    "type": "object",
    "properties": {
        "id": {
            "type": "integer",
            "description": "Primary key, auto-increment"
        },
        "registration_id": {
            "type": "integer",
            "description": "Foreign key to registrations table"
        },
        "event_id": {
            "type": "integer",
            "description": "Foreign key to events table"
        },
        "round": {
            "type": "string",
            "description": "Round name (Qualifying, Round 1, Semi-Final, Final)"
        },
        "sixty_foot": {
            "type": "number",
            "description": "60-foot time in seconds"
        },
        "three_thirty_foot": {
            "type": "number",
            "description": "330-foot time in seconds"
        },
        "eighth_mile_time": {
            "type": "number",
            "description": "1/8 mile time in seconds"
        },
        "eighth_mile_speed": {
            "type": "number",
            "description": "1/8 mile trap speed in mph"
        },
        "quarter_mile_time": {
            "type": "number",
            "description": "1/4 mile time in seconds"
        },
        "quarter_mile_speed": {
            "type": "number",
            "description": "1/4 mile trap speed in mph"
        },
        "reaction_time": {
            "type": "number",
            "description": "Reaction time in seconds"
        },
        "notes": {
            "type": "string",
            "description": "Additional notes about the run"
        },
        "recorded_at": {
            "type": "string",
            "format": "date-time",
            "description": "Time when race was recorded"
        },
        "created_at": {
            "type": "string",
            "format": "date-time",
            "description": "Creation timestamp"
        }
    },
    "required": [
        "id",
        "registration_id",
        "event_id"
    ]
}