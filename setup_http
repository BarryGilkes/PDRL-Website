#!/bin/bash
#
# PDRL Production Setup Script
# Installs and configures the PDRL app to run on:
#   https://pdrl.club
#   https://www.pdrl.club
#
# Server: srv1343245 (187.77.0.185)
# Run as root: bash setup_pdrl.sh
#

DOMAIN="pdrl.club"
SERVER_IP="187.77.0.185"
APP_DIR="/opt/pdrl/app"
BACKEND_DIR="$APP_DIR/backend"
FRONTEND_DIR="$APP_DIR/frontend"
BACKEND_PORT=8000
FRONTEND_PORT=3001

# ─── Colors ───
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
NC='\033[0m'

log_info()    { echo -e "${CYAN}[INFO]${NC}    $(date '+%H:%M:%S') $1"; }
log_success() { echo -e "${GREEN}[OK]${NC}      $(date '+%H:%M:%S') $1"; }
log_warn()    { echo -e "${YELLOW}[WARN]${NC}    $(date '+%H:%M:%S') $1"; }
log_error()   { echo -e "${RED}[ERROR]${NC}   $(date '+%H:%M:%S') $1"; }
log_step()    { echo -e "\n${GREEN}━━━ Step $1: $2 ━━━${NC}"; }

fail() { log_error "$1"; exit 1; }

# ─── Pre-flight checks ───
[[ $EUID -ne 0 ]] && fail "This script must be run as root"
[[ ! -d "$BACKEND_DIR" ]] && fail "Backend directory not found: $BACKEND_DIR"
[[ ! -d "$FRONTEND_DIR" ]] && fail "Frontend directory not found: $FRONTEND_DIR"

echo ""
echo "╔══════════════════════════════════════════════════╗"
echo "║       PDRL Production Setup                      ║"
echo "║       https://pdrl.club                          ║"
echo "║       https://www.pdrl.club                      ║"
echo "╚══════════════════════════════════════════════════╝"
echo ""

# ═══════════════════════════════════════════════════════
log_step "1" "Install system packages"
# ═══════════════════════════════════════════════════════

apt update -y
apt install -y nginx certbot python3-certbot-nginx curl

log_success "System packages installed"

# ═══════════════════════════════════════════════════════
log_step "2" "Verify DNS resolution"
# ═══════════════════════════════════════════════════════

log_info "Checking DNS for $DOMAIN..."
RESOLVED_IP=$(dig +short "$DOMAIN" 2>/dev/null | tail -1)

if [[ "$RESOLVED_IP" == "$SERVER_IP" ]]; then
    log_success "$DOMAIN resolves to $SERVER_IP"
else
    log_warn "$DOMAIN resolves to '$RESOLVED_IP' (expected $SERVER_IP)"
    log_warn "Make sure your DNS A record points $DOMAIN → $SERVER_IP"
    log_warn "Continuing anyway — HTTPS setup will fail if DNS isn't ready"
    echo ""
    read -p "Press Enter to continue, or Ctrl+C to abort..."
fi

RESOLVED_WWW=$(dig +short "www.$DOMAIN" 2>/dev/null | tail -1)
if [[ "$RESOLVED_WWW" == "$SERVER_IP" ]]; then
    log_success "www.$DOMAIN resolves to $SERVER_IP"
else
    log_warn "www.$DOMAIN resolves to '$RESOLVED_WWW' (expected $SERVER_IP)"
    log_warn "Add an A record: www → $SERVER_IP (or CNAME: www → $DOMAIN)"
fi

# ═══════════════════════════════════════════════════════
log_step "3" "Set up Python backend"
# ═══════════════════════════════════════════════════════

cd "$BACKEND_DIR" || fail "Cannot cd to $BACKEND_DIR"

# Activate or create venv
if [[ -d "venv" ]]; then
    log_info "Activating existing venv at $BACKEND_DIR/venv"
    source venv/bin/activate
elif [[ -d ".venv" ]]; then
    log_info "Activating existing venv at $BACKEND_DIR/.venv"
    source .venv/bin/activate
else
    log_info "Creating new venv..."
    python3 -m venv venv
    source venv/bin/activate
fi

log_info "Installing Python dependencies..."
pip install --upgrade pip -q
pip install -r requirements.txt -q
log_success "Python dependencies installed"

# ═══════════════════════════════════════════════════════
log_step "4" "Set up frontend"
# ═══════════════════════════════════════════════════════

cd "$FRONTEND_DIR" || fail "Cannot cd to $FRONTEND_DIR"

# Detect package manager
if command -v pnpm &>/dev/null; then
    PKG_MGR="pnpm"
elif command -v npm &>/dev/null; then
    PKG_MGR="npm"
else
    fail "Neither pnpm nor npm found. Install one first."
fi

log_info "Installing frontend dependencies with $PKG_MGR..."
$PKG_MGR install --silent 2>/dev/null || $PKG_MGR install
log_success "Frontend dependencies installed"

# ═══════════════════════════════════════════════════════
log_step "5" "Update .env files for production"
# ═══════════════════════════════════════════════════════

# Backend .env — ensure DATABASE_URL uses 127.0.0.1 (not localhost)
if [[ -f "$BACKEND_DIR/.env" ]]; then
    log_info "Updating backend .env..."
    sed -i 's|@localhost:|@127.0.0.1:|g' "$BACKEND_DIR/.env"

    # Update FRONTEND_URL if it exists
    if grep -q "^FRONTEND_URL=" "$BACKEND_DIR/.env"; then
        sed -i "s|^FRONTEND_URL=.*|FRONTEND_URL=https://$DOMAIN|" "$BACKEND_DIR/.env"
    else
        echo "FRONTEND_URL=https://$DOMAIN" >> "$BACKEND_DIR/.env"
    fi

    # Ensure PORT is set
    if grep -q "^PORT=" "$BACKEND_DIR/.env"; then
        sed -i "s|^PORT=.*|PORT=$BACKEND_PORT|" "$BACKEND_DIR/.env"
    else
        echo "PORT=$BACKEND_PORT" >> "$BACKEND_DIR/.env"
    fi

    log_success "Backend .env updated"
else
    log_warn "No backend .env found at $BACKEND_DIR/.env"
fi

# App-level .env
if [[ -f "$APP_DIR/.env" ]]; then
    log_info "Updating app-level .env..."
    sed -i 's|@localhost:|@127.0.0.1:|g' "$APP_DIR/.env"
    log_success "App-level .env updated"
fi

# Frontend .env
FRONTEND_ENV="$FRONTEND_DIR/.env"
log_info "Writing frontend .env..."
cat > "$FRONTEND_ENV" <<EOF
VITE_API_BASE_URL=https://$DOMAIN
VITE_FRONTEND_URL=https://$DOMAIN
EOF
log_success "Frontend .env written"

# ═══════════════════════════════════════════════════════
log_step "6" "Test database connection"
# ═══════════════════════════════════════════════════════

cd "$BACKEND_DIR" || fail "Cannot cd to $BACKEND_DIR"
source venv/bin/activate 2>/dev/null || source .venv/bin/activate 2>/dev/null
set -a && source "$BACKEND_DIR/.env" && set +a

log_info "Testing database connection..."
DB_TEST=$(python3 -c "
import asyncio, asyncpg, os
from urllib.parse import urlparse

url = os.environ.get('DATABASE_URL', '')
parsed = urlparse(url)

async def test():
    try:
        conn = await asyncpg.connect(
            user=parsed.username,
            password=parsed.password,
            host=parsed.hostname or '127.0.0.1',
            port=parsed.port or 5432,
            database=parsed.path.lstrip('/')
        )
        result = await conn.fetchval('SELECT 1')
        await conn.close()
        print(f'OK:{parsed.username}@{parsed.hostname}:{parsed.port}/{parsed.path.lstrip(\"/\")}')
    except Exception as e:
        print(f'FAIL:{e}')

asyncio.run(test())
" 2>&1)

if [[ "$DB_TEST" == OK:* ]]; then
    log_success "Database connection verified: ${DB_TEST#OK:}"
else
    log_error "Database connection failed: ${DB_TEST#FAIL:}"
    log_warn "The app may not start correctly. Fix DATABASE_URL in $BACKEND_DIR/.env"
    read -p "Press Enter to continue anyway, or Ctrl+C to abort..."
fi

# ═══════════════════════════════════════════════════════
log_step "7" "Create systemd services"
# ═══════════════════════════════════════════════════════

# Determine the correct venv path
if [[ -d "$BACKEND_DIR/venv" ]]; then
    VENV_PATH="$BACKEND_DIR/venv"
else
    VENV_PATH="$BACKEND_DIR/.venv"
fi

# Backend service
log_info "Creating pdrl-backend.service..."
cat > /etc/systemd/system/pdrl-backend.service <<EOF
[Unit]
Description=PDRL Backend (FastAPI)
After=network.target postgresql.service
Wants=postgresql.service

[Service]
Type=simple
User=root
WorkingDirectory=$BACKEND_DIR
EnvironmentFile=$BACKEND_DIR/.env
Environment=IS_LAMBDA=false
Environment=ENVIRONMENT=prod
Environment=PORT=$BACKEND_PORT
ExecStart=$VENV_PATH/bin/python3 main.py
Restart=always
RestartSec=5
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
EOF

# Frontend service
log_info "Creating pdrl-frontend.service..."
cat > /etc/systemd/system/pdrl-frontend.service <<EOF
[Unit]
Description=PDRL Frontend (Vite)
After=network.target pdrl-backend.service

[Service]
Type=simple
User=root
WorkingDirectory=$FRONTEND_DIR
EnvironmentFile=$FRONTEND_DIR/.env
ExecStart=$(which $PKG_MGR) dev --host 0.0.0.0 --port $FRONTEND_PORT
Restart=always
RestartSec=5
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
EOF

systemctl daemon-reload
log_success "Systemd services created"

# ═══════════════════════════════════════════════════════
log_step "8" "Configure Nginx (HTTP first)"
# ═══════════════════════════════════════════════════════

log_info "Writing Nginx config..."
cat > /etc/nginx/sites-available/pdrl <<'NGINX_EOF'
server {
    listen 80;
    listen [::]:80;
    server_name pdrl.club www.pdrl.club 187.77.0.185;

    # ─── Limits & Timeouts ───
    client_max_body_size 50M;
    proxy_connect_timeout 60s;
    proxy_send_timeout    120s;
    proxy_read_timeout    120s;

    # ─── Common proxy headers ───
    proxy_http_version 1.1;
    proxy_set_header Host              $host;
    proxy_set_header X-Real-IP         $remote_addr;
    proxy_set_header X-Forwarded-For   $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;

    # ─── Backend: all /api/ routes ───
    location /api/ {
        proxy_pass http://127.0.0.1:8000;
    }

    # ─── Backend: root-level endpoints ───
    location = /health {
        proxy_pass http://127.0.0.1:8000;
    }

    location /database/ {
        proxy_pass http://127.0.0.1:8000;
    }

    # ─── Backend: FastAPI docs ───
    location = /docs {
        proxy_pass http://127.0.0.1:8000;
    }

    location = /redoc {
        proxy_pass http://127.0.0.1:8000;
    }

    location = /openapi.json {
        proxy_pass http://127.0.0.1:8000;
    }

    # ─── Frontend: everything else ───
    location / {
        proxy_pass http://127.0.0.1:3001;

        # WebSocket support (Vite HMR)
        proxy_set_header Upgrade    $http_upgrade;
        proxy_set_header Connection "upgrade";
    }
}
NGINX_EOF

# Enable site, disable default
ln -sf /etc/nginx/sites-available/pdrl /etc/nginx/sites-enabled/pdrl
rm -f /etc/nginx/sites-enabled/default

nginx -t || fail "Nginx config test failed"
log_success "Nginx configured"

# ═══════════════════════════════════════════════════════
log_step "9" "Open firewall ports"
# ═══════════════════════════════════════════════════════

if command -v ufw &>/dev/null && ufw status | grep -q "active"; then
    log_info "UFW is active, opening ports 80 and 443..."
    ufw allow 80/tcp
    ufw allow 443/tcp
    ufw allow 'Nginx Full'
    log_success "Firewall ports opened"
else
    log_info "UFW not active, skipping firewall config"
fi

# ═══════════════════════════════════════════════════════
log_step "10" "Stop any existing processes on our ports"
# ═══════════════════════════════════════════════════════

log_info "Killing anything on ports $BACKEND_PORT and $FRONTEND_PORT..."
kill $(lsof -ti :$BACKEND_PORT) 2>/dev/null || true
kill $(lsof -ti :$FRONTEND_PORT) 2>/dev/null || true
sleep 2
log_success "Ports cleared"

# ═══════════════════════════════════════════════════════
log_step "11" "Start services"
# ═══════════════════════════════════════════════════════

log_info "Starting backend..."
systemctl enable pdrl-backend
systemctl start pdrl-backend
sleep 5

# Verify backend is running
if systemctl is-active --quiet pdrl-backend; then
    log_success "Backend is running"
else
    log_error "Backend failed to start. Check: journalctl -u pdrl-backend -n 30"
    log_warn "Continuing with setup..."
fi

log_info "Starting frontend..."
systemctl enable pdrl-frontend
systemctl start pdrl-frontend
sleep 5

if systemctl is-active --quiet pdrl-frontend; then
    log_success "Frontend is running"
else
    log_error "Frontend failed to start. Check: journalctl -u pdrl-frontend -n 30"
    log_warn "Continuing with setup..."
fi

log_info "Starting Nginx..."
systemctl enable nginx
systemctl restart nginx

if systemctl is-active --quiet nginx; then
    log_success "Nginx is running"
else
    fail "Nginx failed to start. Check: journalctl -u nginx -n 30"
fi

# ═══════════════════════════════════════════════════════
log_step "12" "Verify HTTP is working"
# ═══════════════════════════════════════════════════════

log_info "Testing backend through Nginx..."
HEALTH=$(curl -sf http://127.0.0.1/health 2>/dev/null)
if echo "$HEALTH" | grep -q "healthy"; then
    log_success "Backend health check passed"
else
    log_warn "Backend health check failed: $HEALTH"
    log_warn "Check: journalctl -u pdrl-backend -n 30"
fi

log_info "Testing frontend through Nginx..."
HTTP_CODE=$(curl -sf -o /dev/null -w "%{http_code}" http://127.0.0.1/ 2>/dev/null)
if [[ "$HTTP_CODE" == "200" ]]; then
    log_success "Frontend serving on port 80"
else
    log_warn "Frontend returned HTTP $HTTP_CODE"
    log_warn "Check: journalctl -u pdrl-frontend -n 30"
fi

# ═══════════════════════════════════════════════════════
log_step "13" "Set up HTTPS with Let's Encrypt"
# ═══════════════════════════════════════════════════════

log_info "Requesting SSL certificate for $DOMAIN and www.$DOMAIN..."
log_info "This will modify the Nginx config automatically."
echo ""

certbot --nginx \
    -d "$DOMAIN" \
    -d "www.$DOMAIN" \
    --non-interactive \
    --agree-tos \
    --email "admin@$DOMAIN" \
    --redirect

CERT_EXIT=$?

if [[ $CERT_EXIT -eq 0 ]]; then
    log_success "SSL certificate obtained and Nginx configured for HTTPS"
else
    log_error "Certbot failed (exit code $CERT_EXIT)"
    log_warn "This usually means DNS isn't pointing to this server yet."
    log_warn "Once DNS is ready, run manually:"
    log_warn "  certbot --nginx -d $DOMAIN -d www.$DOMAIN"
fi

# ═══════════════════════════════════════════════════════
log_step "14" "Verify HTTPS"
# ═══════════════════════════════════════════════════════

log_info "Testing HTTPS..."
HTTPS_CODE=$(curl -sf -o /dev/null -w "%{http_code}" "https://$DOMAIN/health" 2>/dev/null)
if [[ "$HTTPS_CODE" == "200" ]]; then
    log_success "https://$DOMAIN is working!"
else
    log_warn "https://$DOMAIN returned HTTP $HTTPS_CODE (may need DNS propagation)"
fi

HTTPS_WWW=$(curl -sf -o /dev/null -w "%{http_code}" "https://www.$DOMAIN/" 2>/dev/null)
if [[ "$HTTPS_WWW" == "200" ]] || [[ "$HTTPS_WWW" == "301" ]]; then
    log_success "https://www.$DOMAIN is working!"
else
    log_warn "https://www.$DOMAIN returned HTTP $HTTPS_WWW"
fi

# ═══════════════════════════════════════════════════════
log_step "15" "Set up auto-renewal for SSL"
# ═══════════════════════════════════════════════════════

log_info "Testing certbot auto-renewal..."
certbot renew --dry-run 2>/dev/null
if [[ $? -eq 0 ]]; then
    log_success "Auto-renewal is configured (runs via systemd timer)"
else
    log_warn "Auto-renewal dry run failed. Check: certbot renew --dry-run"
fi

# ═══════════════════════════════════════════════════════
echo ""
echo "╔══════════════════════════════════════════════════╗"
echo "║            SETUP COMPLETE                        ║"
echo "╠══════════════════════════════════════════════════╣"
echo "║                                                  ║"
echo "║  Frontend:  https://pdrl.club                    ║"
echo "║  Frontend:  https://www.pdrl.club                ║"
echo "║  API:       https://pdrl.club/api/v1/health      ║"
echo "║  API Docs:  https://pdrl.club/docs               ║"
echo "║  Health:    https://pdrl.club/health              ║"
echo "║                                                  ║"
echo "╠═══════════════════════════════════════════��══════╣"
echo "║  Manage services:                                ║"
echo "║    systemctl status pdrl-backend                 ║"
echo "║    systemctl status pdrl-frontend                ║"
echo "║    systemctl status nginx                        ║"
echo "║                                                  ║"
echo "║  View logs:                                      ║"
echo "║    journalctl -u pdrl-backend -f                 ║"
echo "║    journalctl -u pdrl-frontend -f                ║"
echo "║    tail -f /var/log/nginx/error.log              ║"
echo "║                                                  ║"
echo "║  Restart everything:                             ║"
echo "║    systemctl restart pdrl-backend                ║"
echo "║    systemctl restart pdrl-frontend               ║"
echo "║    systemctl restart nginx                       ║"
echo "║                                                  ║"
echo "║  Renew SSL manually:                             ║"
echo "║    certbot renew                                 ║"
echo "║                                                  ║"
echo "╚══════════════════════════════════════════════════╝"
echo ""
